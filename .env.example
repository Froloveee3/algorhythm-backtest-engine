# Ports
BT_HTTP_PORT=8090

# Networking (Docker Desktop: host.docker.internal reaches services on the host)
BT_NATS_URL=nats://host.docker.internal:4222
BT_CLICKHOUSE_DSN=clickhouse://default:clickhouse@host.docker.internal:9009/default
BT_CONTROL_PLANE_URL=http://host.docker.internal:8080

# Optional: load feature parquet via M3 reader (requires a reachable MinIO)
# BT_FEATURE_READ_FRAME=true
# BT_MINIO_ENDPOINT=host.docker.internal:9100
# BT_MINIO_ACCESS_KEY=minio
# BT_MINIO_SECRET_KEY=minio123
# BT_MINIO_BUCKET=algorhythm-datasets
# BT_MINIO_USE_SSL=false
